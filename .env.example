# Copy to .env.local for local dev, or run: vercel env pull .env.local
# Server-only secrets — NEVER prefix with VITE_ (that would ship them to the browser).

# Best Buy developer API key (https://developer.bestbuy.com/)
BESTBUY_API_KEY=

# OpenRouter key for the app-held pool account. All model calls bill here.
OPENROUTER_API_KEY=

# Exa web search (metered per-call against user credits)
EXA_API_KEY=

# Postgres (Neon in production; any Postgres works)
DATABASE_URL=

# Clerk auth (read implicitly by @clerk/tanstack-react-start)
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# Upstash Redis — rate limiting + Best Buy proxy cache.
# Optional, but rate limiting is a NO-OP without it. Do not run a public
# instance without Redis configured.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional
ADMIN_EMAILS=            # comma-separated; unlocks the admin pool-sync endpoint
POOL_MODEL_ALLOWLIST=    # comma-separated model ids; overrides the built-in allowlist
VITE_PUBLIC_POSTHOG_KEY= # PostHog analytics; leave empty to disable

# Dev server: extra allowed hostname for phone testing (e.g. a tailnet name)
# DEV_ALLOWED_HOST=
